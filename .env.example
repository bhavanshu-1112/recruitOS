# ============================================
# RecruiterOS — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:5173

# ── PostgreSQL ───────────────────────────────
# Option 1: Neon (cloud) — paste your connection string
DATABASE_URL=postgresql://neondb_owner:<your-password>@<your-endpoint>.neon.tech/neondb?sslmode=require

# Option 2: Local Docker — uncomment these and clear DATABASE_URL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=recruiter_os
# DB_USER=postgres
# DB_PASSWORD=your_db_password_here

# ── Redis ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ── Google OAuth 2.0 ─────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# ── Google Gemini API ────────────────────────
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Google Cloud Storage ─────────────────────
# Service account JSON key path or use Application Default Credentials
GCS_BUCKET_NAME=recruiter-os-uploads
GCS_PROJECT_ID=your_gcp_project_id_here
GOOGLE_APPLICATION_CREDENTIALS=./gcs-service-account.json

# ── Session & JWT ────────────────────────────
SESSION_SECRET=your_session_secret_here_min_32_chars
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Playwright / Scraping ────────────────────
SCRAPER_HEADLESS=true
SCRAPER_TIMEOUT_MS=30000
SCRAPER_MAX_CONCURRENT=3

# ── Logging ──────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=combined
